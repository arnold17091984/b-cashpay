# ============================================================
# B-CashPay Scraper — Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Driver: "sqlite" for development, "mysql" for production.
DB_DRIVER=sqlite
DB_SQLITE_PATH=/Users/maemuraeisuke/Documents/bcashpay/api/database/bcashpay.sqlite

# MySQL production settings (uncomment and fill when DB_DRIVER=mysql):
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bcashpay
# DB_USERNAME=bcashpay_scraper
# DB_PASSWORD=change-me

# ── B-CashPay API ─────────────────────────────────────────────
# Base URL of the running PHP API (no trailing slash).
BCASHPAY_API_URL=http://localhost:8000

# HMAC-SHA256 shared secret — must match BCASHPAY_SCRAPER_SECRET in the API .env.
BCASHPAY_SCRAPER_SECRET=change-me-shared-with-api

# ── Session & screenshot storage ──────────────────────────────
# Where Playwright saves cookies/localStorage between scrape runs.
SCRAPER_SESSION_DIR=/tmp/bcashpay-scraper-sessions

# Where error screenshots are saved (created automatically).
SCRAPER_SCREENSHOT_DIR=/tmp/bcashpay-scraper-screenshots

# ── Scraper control (FastAPI admin API) ───────────────────────
SCRAPER_API_PORT=8020
SCRAPER_API_TOKEN=change-me-for-admin-trigger

# ── Runner behaviour ──────────────────────────────────────────
# Seconds between scheduling loop iterations (continuous mode).
POLL_INTERVAL_SECONDS=60

# Default scrape interval when bank_accounts.scrape_interval_minutes is NULL.
DEFAULT_SCRAPE_INTERVAL_MINUTES=15

# ── Browser ───────────────────────────────────────────────────
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/tmp/bcashpay-scraper-logs
