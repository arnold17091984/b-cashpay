# ============================================================
# B-CashPay API — Environment Configuration
# ============================================================

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.bcashpay.com
APP_SECRET=your-app-secret-change-me

# Database driver: sqlite (local dev) or mysql (production)
DB_DRIVER=sqlite
DB_SQLITE_PATH=./database/bcashpay.sqlite

# For MySQL production:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bcashpay
# DB_USERNAME=bcashpay
# DB_PASSWORD=your-db-password

# Bank Scraper Authentication
# Static bearer token shared with the Python scraper
BANK_SCRAPER_TOKEN=your-scraper-token-change-me

# Payment Page
# Base URL for customer-facing payment pages
PAY_PAGE_URL=https://pay.bcashpay.com
# Secret key for encrypting payment page tokens
PAY_PAGE_SECRET=your-pay-page-secret-32-chars-min

# Payment Link Defaults
PAYMENT_LINK_EXPIRY_HOURS=72
REFERENCE_NUMBER_LENGTH=7

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook Configuration
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=60

# Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW_MINUTES=1

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/bcashpay/api.log
